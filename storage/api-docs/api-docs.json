        "/api/v1/userStoreData": {
            "post": {
                "tags": [
                    "Users"
                ],
                "summary": "Créer",
                "operationId": "f459e93bcb1b906658ebe55e841d30d4",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "John Doe"
                                    },
                                    "email": {
                                        "type": "string",
                                        "example": "john@example.com"
                                    },
                                    "phone": {
                                        "type": "string",
                                        "example": "+243990000000",
                                        "nullable": true
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "secret123"
                                    },
                                    "active": {
                                        "type": "boolean",
                                        "example": true
                                    },
                                    "status": {
                                        "type": "string",
                                        "example": "created"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Données créées avec succès"
                    },
                    "200": {
                        "description": "Données mises à jour avec succès"
                    },
                    "422": {
                        "description": "Validation des données échouée"
                    },
                    "500": {
                        "description": "Erreur serveur"
                    }
                }
            }
        },
        "/api/v1/userUpdateData/{id}": {
            "put": {
                "tags": [
                    "Users"
                ],
                "summary": "Mettre à jour un utilisateur",
                "operationId": "66ff05b10ca8b5907aec7b022bbb7f2c",
