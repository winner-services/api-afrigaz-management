        "/api/v1/aboutStoreData": {
            "post": {
                "tags": [
                    "About"
                ],
                "summary": "Créer ou mettre à jour les informations About",
                "operationId": "921ee414ccdca3253be944e920d7ee24",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "denomination",
                                    "details"
                                ],
                                "properties": {
                                    "denomination": {
                                        "type": "string",
                                        "example": "Afrigaz Express"
                                    },
                                    "details": {
                                        "type": "string",
                                        "example": "Détails de la société"
                                    },
                                    "register": {
                                        "type": "string",
                                        "example": "RC12345"
                                    },
                                    "national_id": {
                                        "type": "string",
                                        "example": "123456789"
                                    },
                                    "tax_number": {
                                        "type": "string",
                                        "example": "TAX123456"
                                    },
                                    "phone": {
                                        "type": "string",
                                        "example": "+243990000000"
                                    },
                                    "address": {
                                        "type": "string",
                                        "example": "Kinshasa, RDC"
                                    },
                                    "email": {
                                        "type": "string",
                                        "example": "contact@afrigaz.com"
                                    },
                                    "logo": {
                                        "description": "Fichier image",
                                        "type": "string",
                                        "format": "binary"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Données créées avec succès"
                    },
                    "200": {
                        "description": "Données mises à jour avec succès"
                    },
                    "422": {
                        "description": "Validation des données échouée"
                    },
                    "500": {
                        "description": "Erreur serveur"
                    }
                }
            }
        },
